# Database Configuration
DATABASE_URL=postgresql://user:password@host:5432/database

# CORS Origins (comma-separated)
# Add your Railway frontend URL here
CORS_ORIGINS=http://localhost:5173,https://your-railway-app.up.railway.app

# Optional: Set to production in Railway
ENVIRONMENT=production

# Required to enable the /admin/* endpoints (reset/reseed). Leave unset to
# disable them entirely. Callers must send it in the X-Admin-Secret header.
ADMIN_SECRET=change-me-long-random-string
